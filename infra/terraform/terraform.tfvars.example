# Copy to terraform.tfvars and fill in. Never commit terraform.tfvars (it is gitignored).

aws_region    = "ap-southeast-1"
project       = "brightify"
instance_type = "t3.medium"          # 4GB; drop to t3.small to stretch the $100 credit
root_volume_gb = 50

# CI deploy (GitHub Actions OIDC)
github_repo   = "giaduocquach/Brightify"
github_branch = "main"
# Set false if your AWS account already has the GitHub OIDC provider.
create_github_oidc_provider = true

# SSH: restrict to your IP (find it: curl ifconfig.me). Empty = SSM-only, no SSH.
ssh_allowed_cidr = ""        # e.g. "203.0.113.4/32"
key_pair_name    = ""        # name of an existing EC2 key pair, or leave empty

# Optional app domain (TLS via Let's Encrypt on nginx). Empty = use the EIP.
domain_name = ""

# CORS origin for audio. "*" is fine for crossOrigin=anonymous media; tighten to
# your domain (e.g. "https://brightify.example.com") once you have one.
app_origins = "*"
