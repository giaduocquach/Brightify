# Brightify — Required Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ===== Database =====
POSTGRES_USER=brightify
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=brightify

# ===== App =====
# For local dev (non-Docker): use localhost
DATABASE_URL=postgresql://brightify:changeme_in_prod@localhost:5432/brightify
# For Docker stack: use service name
# DATABASE_URL=postgresql://brightify:changeme_in_prod@db:5432/brightify
REDIS_URL=redis://redis:6379/0
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# Generate with: openssl rand -hex 32
BRIGHTIFY_ADMIN_KEY=
LOG_LEVEL=INFO

# ===== JWT (if enabled) =====
BRIGHTIFY_JWT_SECRET=

# ===== Spotify API (deprecated — optional) =====
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ===== Serving release mounts =====
# App container reads runtime data from var/serving_releases/current.
# Keep current -> <release_name> symlink valid before deploy.
BRIGHTIFY_ROOT=.
SERVING_RELEASES_PATH=./var/serving_releases
ESSENTIA_MODELS_PATH=./models_cache

# ===== Docker volume backing paths =====
DB_DATA_PATH=./var/volumes/postgres_data
REDIS_DATA_PATH=./var/volumes/redis_data
HF_CACHE_PATH=./var/volumes/hf_cache

# ===== Logging & backup =====
LOGS_PATH=./logs
BACKUPS_PATH=./var/backups

# ===== Optional =====
# Set to 1 in production after HF model warmup to block re-downloads
HF_HUB_OFFLINE=0
SENTRY_DSN=
DOWNLOAD_WORKERS=4

# ===== AWS deployment (docker-compose.aws.yml) =====
# ECR image to run (set by CI/deploy; for manual runs use the SHA or :latest tag)
APP_IMAGE=
# CloudFront distribution in front of the S3 audio bucket (terraform output cloudfront_domain).
# MUST be https:// — the app builds {AUDIO_CDN_BASE}/{track_id}.mp3
AUDIO_CDN_BASE=
# Skip loading PhoBERT at startup (never invoked at runtime). True in prod/AWS.
SKIP_PHOBERT_LOAD=True
# Optional: separate S3 bucket/prefix for DB backups (defaults to the audio bucket)
# BACKUP_S3_BUCKET=
# BACKUP_S3_PREFIX=db-backups
