# Brightify — Required Environment Variables
# Copy this file to .env and fill in the values.

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/brightify_dw

# JWT secret for authentication (generate with: python -c "import secrets; print(secrets.token_hex(32))")
BRIGHTIFY_JWT_SECRET=

# Spotify API credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Download workers for parallel MP3 downloading
DOWNLOAD_WORKERS=4
